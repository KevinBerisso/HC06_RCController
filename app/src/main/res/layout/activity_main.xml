<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Status bar across the top -->
    <View
        android:id="@+id/status_bar"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@color/accent_red"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Status text -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Not connected"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:padding="6dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/status_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- LEFT joystick: DRIVE (throttle) -->
    <com.rccontroller.JoystickView
        android:id="@+id/joystick_left"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_status"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/center_panel"
        app:layout_constraintWidth_percent="0.35"/>

    <!-- Center panel -->
    <LinearLayout
        android:id="@+id/center_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="top|center_horizontal"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_status"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toEndOf="@id/joystick_left"
        app:layout_constraintEnd_toStartOf="@id/joystick_right"
        xmlns:android="http://schemas.android.com/apk/res/android">

        <TextView
            android:text="RC CONTROLLER"
            android:textColor="@color/accent_blue"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:letterSpacing="0.12"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"/>

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Connect HC-06"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:backgroundTint="@color/accent_blue"
            android:stateListAnimator="@null"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="4dp"/>

        <CheckBox
            android:id="@+id/cb_imu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use Phone IMU\nfor Steering"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:buttonTint="@color/accent_blue"
            android:layout_gravity="center"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"/>

        <!-- TX Rate -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:text="TX Rate:"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <SeekBar
                android:id="@+id/seekbar_tx_rate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:max="7"
                android:progress="5"
                android:progressTint="@color/accent_blue"
                android:thumbTint="@color/accent_blue"/>

            <TextView
                android:id="@+id/tv_tx_rate"
                android:layout_width="42dp"
                android:layout_height="wrap_content"
                android:text="20 Hz"
                android:textColor="@color/accent_green"
                android:textSize="10sp"
                android:gravity="end"
                android:fontFamily="monospace"/>

        </LinearLayout>
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_data_out"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="V:+0.0000,D:N,T:0.0000"
            android:textColor="@color/accent_green"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:padding="4dp"/>

        <!-- Legend -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="V: velocity (+fwd/-rev)\nD: direction (L/R/N)\nT: turn magnitude"
            android:textColor="@color/text_hint"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:gravity="center"/>

        <!-- RX Log -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RX from Arduino:"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tv_rx_clear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLEAR"
                android:textColor="@color/accent_blue"
                android:textSize="9sp"
                android:padding="4dp"/>

        </LinearLayout>

        <ScrollView
            android:id="@+id/scroll_rx"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/bg_darker"
            android:padding="4dp"
            android:fadeScrollbars="false">

            <TextView
                android:id="@+id/tv_rx_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/accent_green"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:gravity="bottom"/>

        </ScrollView>

    </LinearLayout>

    <!-- RIGHT joystick: STEER -->
    <com.rccontroller.JoystickView
        android:id="@+id/joystick_right"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_status"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toEndOf="@id/center_panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.35"/>

    <!-- Bottom info bar -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:orientation="horizontal"
        android:background="@color/bg_darker"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        xmlns:android="http://schemas.android.com/apk/res/android">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Left stick: Y = velocity  |  Right stick: X = steer"
            android:textColor="@color/text_hint"
            android:textSize="9sp"
            android:gravity="center"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>